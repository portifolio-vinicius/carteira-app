{
  "expo": {
    "name": "react-native-navegacao-expo",
    "slug": "react-native-navegacao-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-app.svg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-app.svg",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo-app.svg"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo-app.svg"
    }
  }
}
